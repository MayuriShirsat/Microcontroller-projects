   1          //INFORMATION ABOUT RELAY
   2          //there is only one o/p of 5 V in 8051
   3          //relay is used to turn on or off the AC (can be DC) high power components in single signal
   4          //transister is used between them for turning on or off its current should be in such a way that Ibe <=10m
             -A for this r should be 33 ohm to 1 K ohm
   5          //the IC ULN2803 have 8 relays in it
   6          
   7          //note : pulling->opposite to intrrupt i.e. the external message wait untill going on program finish 
   8          //LCD CODE
   9          #include<reg51.h>
  10          sbit rs=P1^0;
  11          sbit en=P1^1;
  12          
  13          void delay(unsigned int count){
  14   1        unsigned int i,j;
  15   1        for(i=0;i<=count;i++){
  16   2          for(j=0;j<1275;j++){}
  17   2          }
  18   1        }
  19          void lcd_data(unsigned char xyz){
  20   1        rs=1;//data is sending on data lines
  21   1        P2=xyz;
  22   1        en=1;
  23   1        delay(50);//enable should be on off through the program 
  24   1        en=0;
  25   1      }
  26          void lcd_comd(unsigned char xyz){
  27   1        rs=0;//comand is sending on data lines
  28   1        P2=xyz;
  29   1        en=1;
  30   1        delay(50);//enable should be on off through the program 
  31   1        en=0;
  32   1      }
  33          void main(){
  34   1        lcd_comd(0x38);//initialize
  35   1        lcd_comd(0x02);//return home
