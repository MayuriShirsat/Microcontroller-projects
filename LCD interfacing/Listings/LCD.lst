  37   1        lcd_comd(0x0C);//Display On Cursor Off
  38   1        lcd_comd(0x06);
  39   1        lcd_comd(0x80);//address of location on row of lcd
  40   1      //for 1st row=0x80
  41   1      //for 2nd row=0xC0
  42   1      //for middle of 1st row=0x85
  43   1      //for middle of 2st row=0xC5  
