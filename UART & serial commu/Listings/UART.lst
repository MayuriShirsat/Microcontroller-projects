   1          #include <reg51.h>
   2          
   3          void uart_init() {                              //SM0 SM1 SM2 REN TB8 RB8 TI RI
   4   1          SCON = 0x50;    // Mode 1, 8-bit UART-> 0x50 = 0   1   0   1   0   0   0  0
   5   1          TMOD = 0x20;    // Timer1 mode2(Always use mode 2 for baud rate) (8-bit auto reload)
   6   1          TH1 = 0xFD;     // Baud rate 9600
   7   1          TL1 = 0xFD;
   8   1          TR1 = 1;        // Start Timer1
   9   1          TI = 1;         // Set TI to indicate ready to transmit
  10   1      }
  11          /*BAUD RATE->
  12          9600  0xFD  253 Most common
  13          4800  0xFA  250 Half of 9600
  14          2400  0xF4  244 Half of 4800
  15          1200  0xE8  232 Half of 2400
  16          19200 0xFE  254 Fast serial communication*/
  17          void main() {
  18   1          uart_init();
  19   1          while(1) {
  20   2              SBUF = 'A';        // Send character on inbuilt SBUF
  21   2              while(TI == 0);    // Wait for transmission complete
  22   2              TI = 0;            // Clear transmit flag
  23   2          }
  24   1      }
  25          
  26          /*Baud Rate=2^SMOD*Oscillator Frequency/32×12×(256-TH1)
  27          Where:
  28          SMOD = 0 or 1 (bit in PCON register, 0 -> default)
  29          Oscillator Frequency = crystal frequency, e.g., 11.0592 MHz
  30          TH1 = reload value for Timer1
  31          Note: TL1 is ignored in auto-reload mode; TH1 is the main reload value.*/ 


