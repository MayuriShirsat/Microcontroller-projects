                    -st) TABS(2) OBJECT(.\Objects\ADC.obj)

line level    source

   1          /*
   2          1.first address lines are given to select the i/p channel
   3          2.ALE is enable(0->1->0) (to latch the address)
   4          3.SOC is enable(0->1->0) to start the conversion
   5          4.continously check the EOC 
   6          5.if EOC(1->0) OE is enable(0->1) (to make data avaliable on port)
   7          6.stop*/
   8          #include<reg51.h>
   9          
  10          sbit X=P2^0;
  11          sbit Y=P2^1;
  12          sbit Z=P2^2;
  13          sbit SOC=P2^3;
  14          sbit ALE=P2^4;
  15          sbit OE=P2^5;
  16          sbit EOC=P2^6;
  17          
  18          unsigned char adc_data;
  19          
  20          void delay(unsigned int ms) {
  21   1          unsigned int i, j;
  22   1          for(i=0; i<ms; i++)
  23   1              for(j=0; j<1275; j++);
  24   1      }
  25          
  26          void start(unsigned char channel){ 
  27   1        X = channel & 0x01;
  28   1        Y = (channel >> 1) & 0x01;
  29   1        Z = (channel >> 2) & 0x01;
  30   1      /*Say channel = 5 ? binary = 101  
  31   1      ->we know 'x & 1 = x'
  32   1      X = 5(101) & 001 = 1 -> A=1
  33   1      Y = (5>>1)(010) & 001 = 0 -> B=0
  34   1      Z = (5>>2)(001) & 001 = 1 -> C=1  */
  35   1        ALE=1;
  36   1        delay(1);
  37   1        ALE=0;
  38   1        SOC=1;
  39   1        delay(1); 
  40   1        SOC=0;
  41   1        
  42   1      while(EOC==1);
  43   1      //the semicolon after while(EOC==1); this means “do nothing while EOC is high”.
  44   1      // do not use if loop  
  45   1      // If you use if(EOC == 1) you only check once.
  46   1      // while(EOC == 1) keeps CPU stuck here until conversion is done  
  47   1      // wait while EOC is high
  48   1      // Now EOC=0 ? conversion finished 
  49   1          OE=1;
  50   1          adc_data=P1;
  51   1          OE=0;
  52   1        }
  53          
  54          void main(){  
C51 COMPILER V9.60.7.0   ADC                                                               09/30/2025 22:44:24 PAGE 2   

  55   1        
  56   1          while(1){
  57   2              start(0);
  58   2              delay(100);
  59   2        }
  60   1      }


