  55   1      }//Every time you call lcd_string,it loops through each character and calls lcd_data() for that character.
  56          //*str dereferences the pointer, giving the current character.
  57          //In C, a string ends with a null character '\0'.
  58          //So while(*str) means: "Keep looping until the current character is '\0'."
