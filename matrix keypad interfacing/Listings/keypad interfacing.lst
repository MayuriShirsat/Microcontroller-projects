  46          // Function to scan keypad
  47          char keypad_scan(){
  48   1          unsigned char row, col;
  49   1        
  50   1          for(row=0; row<4; row++){//The function activates one row at a time.
  51   2              keypad = 0xF0;         // Make columns(P1.7 to P1.4) input, rows(P1.3 to P1.0) output
  52   2      //P1.7 P1.6......P1.0 ->1111 0000
  53   2            keypad &= ~(1<<row);   
  54   2      /*Suppose we have a 4×4 keypad, and we are scanning row 2
C51 COMPILER V9.60.7.0   KEYPAD_INTERFACING                                                10/03/2025 14:18:02 PAGE 2   

  55   2      1)First, (1 << row) -> 1 << 2 = 0000 0100
  56   2      2)Then, ~(1 << row) -> bitwise NOT -> 1111 1011
  57   2      initially keypad value = 1111 1111
  58   2      3)1111 1111 AND 1111 1011 = 1111 1011
  59   2      Only row 2 bit became 0, rest stayed 1      
  60   2      */
  61   2              for(col=0; col<4; col++){//Check each column one by one to see if a key is pressed.
  62   3                  if(!(keypad & (0x10<<col))){ 
  63   4      /*(0x10 << col) -> selects column bit (P1.4–P1.7)
  64   4      col=0 -> P1.4, col=1 -> P1.5, col=2 -> P1.6, col=3 -> P1.7
  65   4      keypad & (0x10 << col) -> reads the column value  
  66   4      (keypad & 0x20) = 0 -> !(0) = 1 -> key detected*/             
  67   4                      while(!(keypad & (0x10<<col))); // Wait for release (debouncing)
  68   4                      return keymap[row][col]; // Return pressed key
  69   4                  }
  70   3              }
  71   2          }
  72   1          return 0; // return 0 if No key pressed
  73   1      }
